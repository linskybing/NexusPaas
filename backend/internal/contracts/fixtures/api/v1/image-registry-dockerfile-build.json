{
  "schema_version": 1,
  "contract_name": "image-registry.dockerfile_build",
  "owner_service": "image-registry-service",
  "api_surface": "external_rest",
  "consumer": "authenticated-user-client",
  "resource": "image-registry-service:image_builds",
  "action": "command",
  "method": "POST",
  "path": "/api/v1/images/build/dockerfile",
